# Copy to .env and fill in your values
# The browser only needs the public Google client ID, never the client secret.
VITE_GOOGLE_CLIENT_ID_DEV=xxxxx-dev.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID_PROD=xxxxx-prod.apps.googleusercontent.com

# Backward-compatible fallback if you still use a single Google OAuth app everywhere.
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

VITE_API_BASE_URL=/api
