{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "knexfile.ts",
    "env.d.ts",
    "routes/**/*.js",
    "middleware/**/*.js",
    "services/**/*.js",
    "db/**/*.js"
  ]
}
