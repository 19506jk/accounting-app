{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@shared/contracts": [
        "../shared/contracts.d.ts"
      ],
      "@shared/*": [
        "../shared/*"
      ]
    },
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "knexfile.ts",
    "env.d.ts",
    "types/**/*.d.ts",
    "types/**/*.ts",
    "middleware/**/*.ts",
    "routes/**/*.js",
    "routes/**/*.ts",
    "middleware/**/*.js",
    "services/**/*.js",
    "services/**/*.ts",
    "db/**/*.js"
  ]
}
