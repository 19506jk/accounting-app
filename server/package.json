{
  "name": "church-accounting-server",
  "version": "1.0.0",
  "description": "Church accounting app — Express API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "NODE_ENV=development nodemon index.js",
    "migrate:dev": "knex migrate:latest --env development",
    "migrate": "npx knex migrate:latest",
    "migrate:rollback": "npx knex migrate:rollback",
    "migrate:status": "npx knex migrate:list",
    "seed": "npx knex seed:run",
    "seed:dev": "knex seed:run --env development",
    "db:reset": "npx knex migrate:rollback --all && npx knex migrate:latest && npx knex seed:run",
    "db:reset-dev": "npx knex migrate:rollback --all --env development && npx knex migrate:latest --env development && npx knex seed:run --env development"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^9.11.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
