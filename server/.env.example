# church-accounting/server/.env.example
# Copy this to .env and fill in your values
# NEVER commit .env to git

NODE_ENV=development

# PORT is read by Express. For this repo's local convention:
# prod/pm2 = 4000, dev API = 5000, test API = 5001, E2E Vite = 5174
PORT=4000

# Shared PostgreSQL host/port for dev and test
DB_HOST=127.0.0.1
DB_PORT=5432

# Development database
DB_NAME_DEV=church_accounting_dev
DB_USER_DEV=church_user
DB_PASSWORD_DEV=changeme

# Test / Playwright database
DB_NAME_TEST=church_accounting_test
DB_USER_TEST=church_user
DB_PASSWORD_TEST=changeme

# Production database connection string
DATABASE_URL_PROD=postgresql://church_user:changeme@localhost:5432/church_accounting

# JWT - use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=replace-with-a-long-random-secret

# Google OAuth - from Google Cloud Console
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Allowed client origin for CORS (defaults to http://localhost:5173 in dev)
CLIENT_ORIGIN=http://localhost:5173
